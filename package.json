		"deploy": "pnpm build && wrangler deploy",
		"deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
		"prepare": "husky",
		"check": "svelte-check-rs",
		"check:watch": "svelte-check-rs --watch",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"knip": "knip",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix"
	},
