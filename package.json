{
	"name": "arcane-website",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"velite": "velite",
		"velite:watch": "velite --watch",
		"dev": "pnpm velite:watch & vp dev --port 3001",
		"dev:wrangler": "pnpm velite:watch & wrangler dev",
		"prebuild": "pnpm velite",
		"build": "vp build",
		"preview": "vp preview",
		"preview:wrangler": "wrangler dev --local",
		"deploy": "pnpm build && wrangler deploy",
		"deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
		"prepare": "vp config",
		"check": "svelte-check-rs",
		"check:watch": "svelte-check-rs --watch",
		"format": "vp fmt",
		"format:check": "vp fmt --check",
		"fallow": "fallow dead-code --fail-on-issues",
		"lint": "vp lint",
		"lint:fix": "vp lint --fix",
		"snyk": "snyk test --all-projects --dev"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "4.0.0-next.0",
		"@sveltejs/enhanced-img": "1.0.0-next.0",
		"mode-watcher": "^1.1.0",
		"rehype-pretty-code": "^0.14.3",
		"rehype-slug": "^6.0.0",
		"remark-code-import": "^1.2.0",
		"remark-gfm": "^4.0.1",
		"unist-builder": "^4.0.0",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@iconify/json": "^2.2.492",
		"@internationalized/date": "^3.12.2",
		"@shikijs/langs": "^4.3.0",
		"@shikijs/themes": "^4.3.0",
		"@sveltejs/kit": "3.0.0-next.4",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^25.9.4",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"fallow": "^2.102.0",
		"isomorphic-dompurify": "^3.18.0",
		"mdsvex": "^0.12.7",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rolldown": "^1.1.3",
		"runed": "^0.37.1",
		"shiki": "^4.3.0",
		"svelte": "^5.56.4",
		"svelte-check-rs": "^0.10.1",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "7.0.1-rc",
		"unplugin-icons": "^23.0.1",
		"velite": "^0.4.0",
		"vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
		"vite-plus": "catalog:",
		"wrangler": "^4.105.0"
